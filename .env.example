# Astro build-time public variables (PUBLIC_* prefix = baked into the client bundle).
# These are NOT Worker runtime vars, so they do NOT belong in wrangler.jsonc.
# Astro/Vite reads them from process.env during `astro build` and inlines them.
#
# Local dev: copy this file to `.env` (git-ignored) and fill in real values.
# Cloudflare Pages / Workers: set the same names in the build environment via
# the Cloudflare dashboard (Settings → Environment variables → Production).

PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
PUBLIC_POSTHOG_PROJECT_TOKEN=""
