---
import { getLocale, t, type Locale } from "../i18n";

const locale: Locale = getLocale(Astro.currentLocale);
const strings = t(locale).howItWorks;
---

<section class="bg-paper-shade/50 px-5 py-16 sm:px-8 sm:py-24 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <h2
      class="font-display text-ink text-3xl leading-tight font-semibold sm:text-4xl"
    >
      {strings.heading}
    </h2>

    <ol class="mt-12 grid gap-6 sm:grid-cols-3">
      {
        strings.steps.map((step, index) => (
          <li class="paper-card relative flex flex-col p-7">
            <span
              class="font-display text-accent bg-accent-soft flex h-10 w-10 items-center justify-center rounded-full text-lg font-semibold"
              aria-hidden="true"
            >
              {index + 1}
            </span>
            <h3 class="text-ink mt-5 text-xl leading-tight font-semibold">
              {step.title}
            </h3>
            <p class="text-ink-muted mt-3 leading-relaxed">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
