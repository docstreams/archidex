---
import { getLocale, t, type Locale } from "../i18n";

const locale: Locale = getLocale(Astro.currentLocale);
const strings = t(locale).problem;
---

<section class="px-5 py-16 sm:px-8 sm:py-24 lg:px-12">
  <div class="mx-auto max-w-5xl">
    <h2
      class="font-display text-ink text-3xl leading-tight font-semibold sm:text-4xl"
    >
      {strings.heading}
    </h2>

    <ul class="mt-10 grid gap-5 sm:grid-cols-3 sm:gap-6">
      {
        strings.pains.map((pain, index) => (
          <li
            class="paper-card relative p-6"
            style={`transform: rotate(${index === 1 ? "0.4deg" : index === 0 ? "-0.6deg" : "0.8deg"})`}
          >
            <span class="font-display text-accent/25 text-5xl leading-none font-semibold">
              «
            </span>
            <p class="text-ink -mt-2 text-lg leading-relaxed">{pain}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
