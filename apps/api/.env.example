# API Keys
MISTRAL_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# CORS (comma-separated origins; leave empty for dev defaults)
CORS_ORIGINS=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Storage
UPLOAD_DIR=./data/uploads
SQLITE_PATH=./data/registry.db

# Upload / processing
UPLOAD_MAX_SIZE_MB=10
MAX_CONCURRENT_PROCESSING=2

# RAG parameters
MAX_CHAT_HISTORY=10
RETRIEVAL_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM
LLM_MODEL=gemini-2.5-flash

# Usage limits (demo safeguards)
LIMIT_OCR_PAGES=100
LIMIT_EMBEDDING_TOKENS=500000
LIMIT_LLM_TOKENS=1000000

