---
import { getLocale, t, type Locale } from "../i18n";

const locale: Locale = getLocale(Astro.currentLocale);
const strings = t(locale).pricing;
---

<section id="pricing" class="scroll-mt-24 px-5 py-16 sm:px-8 sm:py-24 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <h2
        class="font-display text-ink text-3xl leading-tight font-semibold sm:text-4xl"
      >
        {strings.heading}
      </h2>
      <p class="text-ink-muted mt-4 text-lg leading-relaxed">
        {strings.subhead}
      </p>
    </div>

    <ul class="mt-12 grid gap-5 md:grid-cols-3 md:gap-6">
      {
        strings.plans.map((plan) => (
          <li
            class:list={[
              "relative flex flex-col p-7",
              plan.recommended ? "paper-card-lifted" : "paper-card",
            ]}
          >
            {plan.recommended && (
              <span class="bg-accent absolute -top-3 left-7 rounded-full px-3 py-1 text-[0.68rem] font-medium tracking-[0.18em] text-white uppercase">
                {strings.recommendedBadge}
              </span>
            )}

            <div>
              <h3 class="text-ink text-xl leading-tight font-semibold">
                {plan.name}
              </h3>
              <p class="text-ink-muted mt-1 text-sm leading-relaxed">
                {plan.tagline}
              </p>
            </div>

            <div class="mt-6 flex items-baseline gap-2">
              {plan.price ? (
                <>
                  <span class="font-display text-ink text-4xl font-semibold">
                    {plan.price}
                  </span>
                  <span class="text-ink-muted text-sm">{plan.priceUnit}</span>
                </>
              ) : (
                <span class="font-display text-ink text-3xl font-semibold">
                  {strings.contactPrice}
                </span>
              )}
            </div>

            <ul class="mt-6 flex flex-col gap-2.5">
              {plan.features.map((feature) => (
                <li class="text-ink-muted flex gap-2 text-sm leading-relaxed">
                  <svg
                    class="text-accent mt-0.5 h-4 w-4 shrink-0"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M3 8l3.5 3.5L13 5" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="mt-8 pt-2">
              <a
                href="#beta-apply"
                class:list={[
                  "w-full",
                  plan.recommended ? "btn-primary" : "btn-ghost",
                ]}
              >
                {plan.cta}
              </a>
            </div>
          </li>
        ))
      }
    </ul>

    <div class="mt-14">
      <p
        class="text-ink-soft text-[0.72rem] font-medium tracking-[0.22em] uppercase"
      >
        {strings.addonsHeading}
      </p>
      <ul class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          strings.addons.map((addon) => (
            <li class="paper-card flex flex-col p-5 sm:flex-row sm:items-start sm:gap-5">
              <div class="flex-1">
                <h3 class="text-ink text-base leading-tight font-semibold">
                  {addon.name}
                </h3>
                <p class="text-ink-muted mt-1.5 text-sm leading-relaxed">
                  {addon.description}
                </p>
              </div>
              <p class="text-accent mt-3 text-sm font-medium sm:mt-1 sm:text-right">
                {addon.price}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
