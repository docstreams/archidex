---
import { getLocale, t, type Locale } from "../i18n";

const locale: Locale = getLocale(Astro.currentLocale);
const strings = t(locale).betaApply;

const inputClass =
  "border-line focus:border-accent text-ink placeholder:text-ink-soft/70 rounded-xl border bg-white px-3.5 py-2.5 text-base focus:outline-none aria-invalid:border-red-500 aria-invalid:focus:border-red-500";
const fieldErrorClass = "hidden text-xs text-red-700";
---

<section
  id="beta-apply"
  class="scroll-mt-24 px-5 py-16 sm:px-8 sm:py-24 lg:px-12"
>
  <div class="mx-auto max-w-4xl">
    <div
      class="paper-card-lifted grid gap-0 overflow-hidden sm:grid-cols-[1fr_280px]"
    >
      <div class="p-7 sm:p-10">
        <div data-form-intro>
          <h2
            class="font-display text-ink text-3xl leading-tight font-semibold sm:text-4xl"
          >
            {strings.heading}
          </h2>
          <p class="text-ink-muted mt-3 text-base leading-relaxed sm:text-lg">
            {strings.subhead}
          </p>

          <div
            class="border-line bg-paper-shade/50 mt-6 rounded-2xl border p-4 sm:p-5"
          >
            <p
              class="text-ink-soft text-[0.72rem] font-medium tracking-[0.22em] uppercase"
            >
              {strings.fitLabel}
            </p>

            <ul class="mt-3 flex flex-col gap-2">
              {
                strings.fitItems.map((item) => (
                  <li class="text-ink flex items-start gap-2 text-sm leading-relaxed">
                    <span class="text-accent mt-0.5" aria-hidden="true">
                      •
                    </span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <form
            id="beta-apply-form"
            class="mt-8 flex flex-col gap-4"
            data-locale={locale}
            data-default-error={strings.fieldErrors.name}
            novalidate
          >
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="flex flex-col gap-1.5 text-sm">
                <span class="text-ink font-medium">{strings.labels.name}</span>
                <input
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder={strings.placeholders.name}
                  aria-describedby="beta-error-name"
                  class={inputClass}
                />
                <p
                  id="beta-error-name"
                  data-field-error="name"
                  class={fieldErrorClass}
                  role="alert"
                >
                  {strings.fieldErrors.name}
                </p>
              </label>
              <label class="flex flex-col gap-1.5 text-sm">
                <span class="text-ink font-medium">{strings.labels.email}</span>
                <input
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder={strings.placeholders.email}
                  aria-describedby="beta-error-email"
                  class={inputClass}
                />
                <p
                  id="beta-error-email"
                  data-field-error="email"
                  class={fieldErrorClass}
                  role="alert"
                >
                  {strings.fieldErrors.email}
                </p>
              </label>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <label class="flex flex-col gap-1.5 text-sm">
                <span class="text-ink font-medium"
                  >{strings.labels.company}</span
                >
                <input
                  type="text"
                  name="company"
                  required
                  autocomplete="organization"
                  placeholder={strings.placeholders.company}
                  aria-describedby="beta-error-company"
                  class={inputClass}
                />
                <p
                  id="beta-error-company"
                  data-field-error="company"
                  class={fieldErrorClass}
                  role="alert"
                >
                  {strings.fieldErrors.company}
                </p>
              </label>
              <label class="flex flex-col gap-1.5 text-sm">
                <span class="text-ink font-medium">{strings.labels.role}</span>
                <input
                  type="text"
                  name="role"
                  autocomplete="organization-title"
                  placeholder={strings.placeholders.role}
                  class={inputClass}
                />
              </label>
            </div>

            <label class="flex flex-col gap-1.5 text-sm">
              <span class="text-ink font-medium">{strings.labels.size}</span>
              <select
                name="size"
                required
                aria-describedby="beta-error-size"
                class={inputClass}
              >
                <option value="" disabled selected>—</option>
                {
                  strings.sizeOptions.map((size) => (
                    <option value={size}>{size}</option>
                  ))
                }
              </select>
              <p
                id="beta-error-size"
                data-field-error="size"
                class={fieldErrorClass}
                role="alert"
              >
                {strings.fieldErrors.size}
              </p>
            </label>

            <label class="flex flex-col gap-1.5 text-sm">
              <span class="text-ink font-medium">{strings.labels.useCase}</span>
              <textarea
                name="useCase"
                rows="3"
                placeholder={strings.placeholders.useCase}
                class={`${inputClass} resize-y`}></textarea>
            </label>

            <div class="sr-only" aria-hidden="true">
              <label>
                Website (leave empty)
                <input
                  type="text"
                  name="website"
                  tabindex="-1"
                  autocomplete="off"
                />
              </label>
            </div>

            <button
              type="submit"
              class="btn-primary mt-2 self-start disabled:cursor-not-allowed disabled:opacity-60"
              data-label-idle={strings.submit}
              data-label-sending={strings.sending}
            >
              {strings.submit}
            </button>

            <p class="text-ink-soft mt-1 text-xs leading-relaxed">
              {strings.privacy}
            </p>

            <p
              data-form-error
              class="hidden text-sm text-red-700"
              role="alert"
              aria-live="polite"
            >
              {strings.error}
            </p>
          </form>
        </div>

        <div data-form-success class="hidden" role="status" aria-live="polite">
          <h2
            class="font-display text-ink text-3xl leading-tight font-semibold sm:text-4xl"
          >
            {strings.success.heading}
          </h2>
          <p class="text-ink-muted mt-3 text-base leading-relaxed sm:text-lg">
            {strings.success.body}
          </p>
        </div>
      </div>

      <aside
        class="border-line bg-paper-shade/50 hidden items-end justify-center border-l p-6 sm:flex"
        aria-hidden="true"
      >
        <img
          data-mascot-idle
          src="/mascot/dex-form.webp"
          alt={strings.mascotAlt}
          class="h-56 w-auto object-contain"
          width="280"
          height="280"
          loading="lazy"
          decoding="async"
        />
        <img
          data-mascot-success
          src="/mascot/dex-success.webp"
          alt={strings.mascotAlt}
          class="hidden h-56 w-auto object-contain"
          width="280"
          height="280"
          loading="lazy"
          decoding="async"
        />
      </aside>
    </div>
  </div>
</section>

<script>
  type FieldName = "name" | "email" | "company" | "size";

  interface BetaApplyResponse {
    success: boolean;
    message?: string;
    error?: string;
    fieldErrors?: Partial<Record<FieldName, string>>;
  }

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const form = document.getElementById(
    "beta-apply-form",
  ) as HTMLFormElement | null;

  if (form) {
    const button = form.querySelector<HTMLButtonElement>(
      'button[type="submit"]',
    );
    const errorEl = form.querySelector<HTMLElement>("[data-form-error]");
    const introEl = form.closest<HTMLElement>("[data-form-intro]");
    const card = introEl?.parentElement?.parentElement;
    const successEl = introEl?.parentElement?.querySelector<HTMLElement>(
      "[data-form-success]",
    );
    const mascotIdle = card?.querySelector<HTMLElement>("[data-mascot-idle]");
    const mascotSuccess = card?.querySelector<HTMLElement>(
      "[data-mascot-success]",
    );

    const idleLabel = button?.dataset.labelIdle ?? "Submit";
    const sendingLabel = button?.dataset.labelSending ?? "Sending…";

    const errorNodes = new Map<FieldName, HTMLElement>();
    form.querySelectorAll<HTMLElement>("[data-field-error]").forEach((node) => {
      const field = node.dataset.fieldError as FieldName | undefined;
      if (field) errorNodes.set(field, node);
    });

    const inputs: Record<
      FieldName,
      HTMLInputElement | HTMLSelectElement | null
    > = {
      name: form.elements.namedItem("name") as HTMLInputElement | null,
      email: form.elements.namedItem("email") as HTMLInputElement | null,
      company: form.elements.namedItem("company") as HTMLInputElement | null,
      size: form.elements.namedItem("size") as HTMLSelectElement | null,
    };

    const defaultMessages: Record<FieldName, string> = {
      name: errorNodes.get("name")?.textContent?.trim() ?? "",
      email: errorNodes.get("email")?.textContent?.trim() ?? "",
      company: errorNodes.get("company")?.textContent?.trim() ?? "",
      size: errorNodes.get("size")?.textContent?.trim() ?? "",
    };

    function setFieldError(field: FieldName, message: string | null) {
      const node = errorNodes.get(field);
      const input = inputs[field];
      if (!node || !input) return;
      if (message) {
        node.textContent = message;
        node.classList.remove("hidden");
        input.setAttribute("aria-invalid", "true");
      } else {
        node.textContent = defaultMessages[field];
        node.classList.add("hidden");
        input.removeAttribute("aria-invalid");
      }
    }

    function clearAllFieldErrors() {
      (Object.keys(inputs) as FieldName[]).forEach((f) =>
        setFieldError(f, null),
      );
    }

    (Object.keys(inputs) as FieldName[]).forEach((field) => {
      const input = inputs[field];
      if (!input) return;
      input.addEventListener("input", () => setFieldError(field, null));
      input.addEventListener("change", () => setFieldError(field, null));
    });

    function validateLocally(payload: {
      name: string;
      email: string;
      company: string;
      size: string;
    }): FieldName | null {
      if (!payload.name) return "name";
      if (!payload.email || !EMAIL_RE.test(payload.email)) return "email";
      if (!payload.company) return "company";
      if (!payload.size) return "size";
      return null;
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!button) return;
      errorEl?.classList.add("hidden");
      clearAllFieldErrors();

      const formData = new FormData(form);
      const website = ((formData.get("website") as string) || "").trim();
      if (website.length > 0) {
        return;
      }

      const payload = {
        name: ((formData.get("name") as string) ?? "").trim(),
        email: ((formData.get("email") as string) ?? "").trim(),
        company: ((formData.get("company") as string) ?? "").trim(),
        role: ((formData.get("role") as string) ?? "").trim(),
        size: ((formData.get("size") as string) ?? "").trim(),
        useCase: ((formData.get("useCase") as string) ?? "").trim(),
        locale: form.dataset.locale ?? "uk",
      };

      const localFailure = validateLocally(payload);
      if (localFailure) {
        setFieldError(localFailure, defaultMessages[localFailure]);
        inputs[localFailure]?.focus();
        return;
      }

      button.disabled = true;
      button.textContent = sendingLabel;
      form.setAttribute("aria-busy", "true");

      try {
        const response = await fetch("/api/beta-apply", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const data = (await response
          .json()
          .catch(() => null)) as BetaApplyResponse | null;

        if (!response.ok || !data?.success) {
          if (data?.fieldErrors) {
            const failingFields: FieldName[] = [];
            (Object.keys(data.fieldErrors) as FieldName[]).forEach((field) => {
              const msg = data.fieldErrors?.[field];
              if (msg) {
                setFieldError(field, defaultMessages[field] ?? msg);
                failingFields.push(field);
              }
            });
            const firstField = failingFields[0];
            if (firstField) inputs[firstField]?.focus();
          } else {
            errorEl?.classList.remove("hidden");
          }
          button.disabled = false;
          button.textContent = idleLabel;
          form.removeAttribute("aria-busy");
          return;
        }

        introEl?.classList.add("hidden");
        successEl?.classList.remove("hidden");
        mascotIdle?.classList.add("hidden");
        mascotSuccess?.classList.remove("hidden");
      } catch {
        errorEl?.classList.remove("hidden");
        button.disabled = false;
        button.textContent = idleLabel;
        form.removeAttribute("aria-busy");
      }
    });
  }
</script>
