---
import { getLocale, t, type Locale } from "../i18n";

const locale: Locale = getLocale(Astro.currentLocale);
const strings = t(locale).hero;
---

<section
  class="relative overflow-hidden px-5 pt-10 pb-16 sm:px-8 sm:pt-16 sm:pb-24 lg:px-12"
>
  <div
    class="from-paper-shade/60 via-paper to-paper pointer-events-none absolute inset-x-0 top-0 -z-10 h-130 bg-linear-to-b"
    aria-hidden="true"
  >
  </div>

  <div
    class="mx-auto grid max-w-7xl gap-10 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-16"
  >
    <div>
      <p
        class="border-line bg-paper-shade/70 text-ink-muted inline-flex max-w-full rounded-full border px-4 py-1.5 text-sm leading-snug font-medium"
      >
        {strings.kicker}
      </p>

      <h1
        class="font-display text-ink mt-5 max-w-3xl text-4xl leading-[1.05] font-semibold sm:text-5xl lg:text-6xl"
      >
        {strings.headline}
      </h1>

      <p class="text-ink-muted mt-6 max-w-2xl text-lg leading-relaxed">
        {strings.subhead}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#beta-apply" class="btn-primary">
          {strings.cta}
          <svg
            class="h-4 w-4"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h10m0 0L9 4m4 4l-4 4"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>

      <ul class="mt-8 flex flex-wrap gap-3" aria-label={strings.proofLabel}>
        {
          strings.proofPoints.map((point) => (
            <li class="border-line text-ink rounded-full border bg-white/80 px-4 py-2 text-sm leading-snug font-medium shadow-sm">
              {point}
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <div class="relative mx-auto w-full max-w-xl">
        <div
          class="from-accent-soft/80 via-paper-shade/50 absolute inset-x-4 -top-4 -bottom-4 -z-10 rounded-[2rem] bg-linear-to-br to-transparent blur-2xl sm:inset-x-8 sm:-top-6 sm:-bottom-8"
          aria-hidden="true"
        >
        </div>

        <div class="relative flex flex-col gap-4 sm:gap-5">
          <div class="paper-card-lifted relative overflow-hidden p-4 sm:p-8">
            <div
              class="from-paper pointer-events-none absolute inset-x-0 top-0 h-24 bg-linear-to-b to-transparent"
              aria-hidden="true"
            >
            </div>

            <div class="relative">
              <p
                class="text-ink-soft text-[0.68rem] font-medium tracking-[0.18em] uppercase sm:text-[0.72rem] sm:tracking-[0.22em]"
              >
                {strings.panelEyebrow}
              </p>

              <ul class="mt-5 space-y-3" aria-label={strings.archiveLabel}>
                {
                  strings.archiveItems.map((item) => (
                    <li class="border-line bg-paper/70 rounded-2xl border px-4 py-3 shadow-sm sm:flex sm:items-center sm:justify-between sm:gap-4">
                      <div class="flex min-w-0 items-center gap-3">
                        <span
                          class="bg-accent-soft text-accent inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
                          aria-hidden="true"
                        >
                          <svg
                            class="h-4 w-4"
                            viewBox="0 0 16 16"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path d="M2.75 4.75h3l1.2 1.5h6.3v5.5a1.5 1.5 0 0 1-1.5 1.5h-7.5a1.5 1.5 0 0 1-1.5-1.5z" />
                            <path d="M2.75 4.75a1.5 1.5 0 0 1 1.5-1.5h2.1l1.2 1.5" />
                          </svg>
                        </span>
                        <div class="min-w-0">
                          <p class="text-ink truncate text-sm font-semibold sm:text-base">
                            {item.title}
                          </p>
                          <p class="text-ink-muted mt-0.5 text-xs sm:text-sm">
                            {item.meta}
                          </p>
                        </div>
                      </div>

                      <span class="text-ink-soft mt-3 inline-flex shrink-0 text-xs font-medium sm:mt-0">
                        {item.badge}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <div
            class="paper-card relative self-end p-5 sm:mr-8 sm:max-w-sm sm:p-6"
          >
            <span
              class="font-display text-accent bg-accent-soft flex h-10 w-10 items-center justify-center rounded-full text-lg font-semibold"
              aria-hidden="true"
            >
              ?
            </span>
            <p
              class="text-ink-soft mt-4 text-[0.68rem] font-medium tracking-[0.18em] uppercase sm:text-[0.72rem] sm:tracking-[0.2em]"
            >
              {strings.questionLabel}
            </p>
            <p class="text-ink mt-2 text-base font-semibold sm:text-lg">
              {strings.questionText}
            </p>
          </div>

          <div
            class="pointer-events-none hidden lg:flex lg:justify-end lg:pr-6 xl:pr-8"
          >
            <img
              src="/mascot/dex-hero.webp"
              alt={strings.mascotAlt}
              class="h-28 w-auto object-contain xl:h-32"
              width="640"
              height="640"
              loading="eager"
              decoding="async"
            />
          </div>

          <div
            class="paper-card-lifted relative z-10 self-start p-4 sm:ml-10 sm:max-w-md sm:p-5"
          >
            <p
              class="text-ink-soft text-[0.68rem] font-medium tracking-[0.18em] uppercase sm:text-[0.72rem] sm:tracking-[0.2em]"
            >
              {strings.answerLabel}
            </p>
            <p class="text-ink mt-2 text-base font-semibold sm:text-lg">
              {strings.answerTitle}
            </p>
            <p class="text-ink-muted mt-2 text-sm leading-relaxed sm:text-base">
              {strings.answerText}
            </p>

            <div class="border-line mt-4 border-t pt-3">
              <p
                class="text-ink-soft text-[0.68rem] font-medium tracking-[0.2em] uppercase"
              >
                {strings.sourceLabel}
              </p>
              <p class="text-ink mt-1 text-sm font-medium">
                {strings.sourceText}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
