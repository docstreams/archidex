---
import { getLocale, t, type Locale } from "../i18n";

const locale: Locale = getLocale(Astro.currentLocale);
const strings = t(locale).productMock;
---

<section class="px-5 py-16 sm:px-8 sm:py-24 lg:px-12">
  <div class="mx-auto max-w-5xl">
    <div class="max-w-2xl">
      <h2
        class="font-display text-ink text-3xl leading-tight font-semibold sm:text-4xl"
      >
        {strings.heading}
      </h2>
      <p class="text-ink-muted mt-4 text-lg leading-relaxed">
        {strings.subhead}
      </p>
    </div>

    <div class="paper-card-lifted mt-12 overflow-hidden">
      <div
        class="border-line bg-paper-shade/40 flex items-center justify-between border-b px-5 py-3"
      >
        <div class="flex items-center gap-2">
          <span class="block h-2.5 w-2.5 rounded-full bg-[#e8c8c0]"></span>
          <span class="block h-2.5 w-2.5 rounded-full bg-[#ead9b7]"></span>
          <span class="block h-2.5 w-2.5 rounded-full bg-[#c6d9c1]"></span>
        </div>
        <span class="text-ink-soft font-sans text-xs tracking-wide">
          docbuddy.app
        </span>
        <span class="w-10"></span>
      </div>

      <div class="grid gap-0 sm:grid-cols-[1fr_auto] sm:items-stretch">
        <div class="flex flex-col gap-5 p-6 sm:p-8">
          <div class="flex justify-end">
            <div
              class="bg-accent max-w-[85%] rounded-2xl rounded-br-md px-4 py-3 text-white shadow-sm sm:max-w-[80%]"
            >
              <p class="text-sm leading-relaxed sm:text-base">
                {strings.question}
              </p>
            </div>
          </div>

          <div class="flex justify-start">
            <div class="max-w-full sm:max-w-[90%]">
              <div
                class="border-line rounded-2xl rounded-bl-md border bg-white px-5 py-4 shadow-sm"
              >
                <p class="text-ink text-sm leading-relaxed sm:text-base">
                  {strings.answer}
                </p>

                <a
                  href="#"
                  class="bg-paper-shade/70 hover:bg-paper-shade focus-visible:ring-accent/30 mt-4 flex items-start gap-3 rounded-xl px-3 py-2.5 transition-colors focus-visible:ring-2 focus-visible:outline-none"
                  aria-label={`${strings.citationLabel}: ${strings.citationDoc}, ${strings.citationPage}`}
                >
                  <span
                    class="bg-accent-soft text-accent mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md"
                    aria-hidden="true"
                  >
                    <svg
                      class="h-4 w-4"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 2h5l3 3v9H4z"></path>
                      <path d="M9 2v4h3"></path>
                    </svg>
                  </span>
                  <span class="flex flex-col text-left">
                    <span
                      class="text-ink-soft text-[0.7rem] font-medium tracking-wide uppercase"
                    >
                      {strings.citationLabel}
                    </span>
                    <span class="text-ink text-sm font-medium">
                      {strings.citationDoc}
                    </span>
                    <span class="text-ink-muted text-xs">
                      {strings.citationPage}
                    </span>
                  </span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <aside
          class="border-line bg-paper-shade/40 hidden items-end justify-center border-l p-6 sm:flex"
          aria-hidden="true"
        >
          <img
            src="/mascot/octik-working.webp"
            alt={strings.emptyStateAlt}
            class="h-44 w-auto object-contain"
            width="220"
            height="220"
            loading="lazy"
            decoding="async"
          />
        </aside>
      </div>
    </div>
  </div>
</section>
